rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authorized() { return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    match /users/{uid} { allow read: if request.auth != null && request.auth.uid == uid; allow write: if false; }
    match /businesses/{businessId}/{document=**} { allow read, write: if authorized() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId; }
  }
}
