rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function firstOwner() { return signedIn() && request.auth.token.email == 'murillo.charles97@gmail.com' && !exists(/databases/$(database)/documents/businesses/adi-festa); }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function authorized() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && profile().active == true; }
    function canAccess(businessId) { return authorized() && profile().businessId == businessId; }
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if request.auth.uid == uid && firstOwner() && request.resource.data.email == request.auth.token.email && request.resource.data.role == 'admin' && request.resource.data.active == true && request.resource.data.businessId == 'adi-festa';
      allow update: if authorized()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && (!('uid' in resource.data) || resource.data.uid == request.auth.uid)
        && request.resource.data.email == resource.data.email
        && request.resource.data.active == resource.data.active
        && request.resource.data.businessId == resource.data.businessId
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }
    match /publicCatalogs/{visitToken} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && request.resource.data.businessId is string
        && canAccess(request.resource.data.businessId);
      allow delete: if false;
      match /orders/{orderId} {
        allow create: if get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.active == true
          && request.resource.data.id == orderId
          && request.resource.data.catalogToken == visitToken
          && request.resource.data.source == 'online_catalog'
          && request.resource.data.orderStatus == 'recebido'
          && request.resource.data.customerName is string
          && request.resource.data.customerName.size() > 1
          && request.resource.data.customerName.size() <= 120
          && request.resource.data.customerPhone is string
          && request.resource.data.customerPhone.size() >= 10
          && request.resource.data.customerPhone.size() <= 15
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 40
          && request.resource.data.total is number
          && request.resource.data.total > 0
          && request.resource.data.total <= 10000
          && request.resource.data.subtotal == request.resource.data.total
          && request.resource.data.discount == 0
          && request.resource.data.fee == 0
          && request.resource.data.paymentPreference in ['entrega', 'pix', 'dinheiro', 'cartao', 'fiado']
          && request.resource.data.orderAccessToken is string
          && request.resource.data.orderAccessToken.size() >= 24;
        allow get: if true;
        allow list: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow update: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /campaignProgress/{phoneHash} {
        allow get: if true;
        allow list: if false;
        allow create, update: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /phoneIndex/{phoneHash} {
        allow get: if true;
        allow list: if false;
        allow create, update: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /portalProfiles/{clientRefToken} {
        allow get: if true;
        allow list: if false;
        allow create, update: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /portalSessions/{sessionHash} {
        allow get: if true;
        allow list: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow create: if get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.active == true
          && request.resource.data.active == true
          && request.resource.data.businessId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId
          && request.resource.data.visitId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.visitId
          && request.resource.data.clientRefToken is string
          && request.resource.data.clientRefToken.size() >= 20
          && request.resource.data.expiresAt is string
          && exists(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalProfiles/$(request.resource.data.clientRefToken));
        allow update: if canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId)
          || (resource.data.active == true
            && request.resource.data.businessId == resource.data.businessId
            && request.resource.data.visitId == resource.data.visitId
            && request.resource.data.clientRefToken == resource.data.clientRefToken
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastAccessAt', 'updatedAt', 'active', 'revokedAt']));
        allow delete: if false;
      }
      match /redemptionRequests/{requestId} {
        allow create: if request.resource.data.id == requestId
          && request.resource.data.status == 'solicitado'
          && request.resource.data.businessId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId
          && request.resource.data.visitId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.visitId
          && request.resource.data.clientRefToken is string
          && request.resource.data.portalSessionHash is string
          && exists(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalSessions/$(request.resource.data.portalSessionHash))
          && get(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalSessions/$(request.resource.data.portalSessionHash)).data.active == true
          && get(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalSessions/$(request.resource.data.portalSessionHash)).data.clientRefToken == request.resource.data.clientRefToken;
        allow get: if true;
        allow list, update: if signedIn() && canAccess(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
    }
    match /businesses/{businessId} {
      allow create: if businessId == 'adi-festa' && firstOwner() && request.resource.data.ownerId == request.auth.uid;
      allow read: if canAccess(businessId);
      allow update: if canAccess(businessId) && ((resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId) || (request.auth.token.email == 'murillo.charles97@gmail.com' && profile().role == 'admin' && request.resource.data.ownerId == request.auth.uid));
      allow delete: if false;
      match /{document=**} {
        allow read, create, update: if canAccess(businessId);
        allow delete: if false;
      }
    }
  }
}
