rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function firstOwner() { return signedIn() && request.auth.token.email == 'murillo.charles97@gmail.com' && !exists(/databases/$(database)/documents/businesses/adi-festa); }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function authorized() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && profile().active == true; }
    function canAccess(businessId) { return authorized() && profile().businessId == businessId; }
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if request.auth.uid == uid && firstOwner() && request.resource.data.email == request.auth.token.email && request.resource.data.role == 'admin' && request.resource.data.active == true && request.resource.data.businessId == 'adi-festa';
      allow update: if authorized()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && (!('uid' in resource.data) || resource.data.uid == request.auth.uid)
        && request.resource.data.email == resource.data.email
        && request.resource.data.active == resource.data.active
        && request.resource.data.businessId == resource.data.businessId
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }
    match /businesses/{businessId} {
      allow create: if businessId == 'adi-festa' && firstOwner() && request.resource.data.ownerId == request.auth.uid;
      allow read: if canAccess(businessId);
      allow update: if canAccess(businessId) && ((resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId) || (request.auth.token.email == 'murillo.charles97@gmail.com' && profile().role == 'admin' && request.resource.data.ownerId == request.auth.uid));
      allow delete: if false;
      match /{document=**} {
        allow read, create, update: if canAccess(businessId);
        allow delete: if false;
      }
    }
  }
}
