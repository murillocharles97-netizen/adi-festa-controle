rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function profileExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function validRole(role) {
      return role in ['owner', 'admin', 'manager', 'cashier', 'viewer', 'platform_admin'];
    }
    function activeUser() {
      return profileExists() && userProfile().active == true && validRole(userProfile().role);
    }
    function currentBusinessId() {
      return userProfile().businessId;
    }
    function businessExists(businessId) {
      return exists(/databases/$(database)/documents/businesses/$(businessId));
    }
    function activeBusiness(businessId) {
      return businessExists(businessId)
        && get(/databases/$(database)/documents/businesses/$(businessId)).data.active == true;
    }
    function belongsToBusiness(businessId) {
      return activeUser()
        && currentBusinessId() == businessId
        && activeBusiness(businessId);
    }
    function isOwner(businessId) {
      return belongsToBusiness(businessId)
        && userProfile().role == 'owner'
        && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }
    function isAdmin(businessId) {
      return belongsToBusiness(businessId) && userProfile().role in ['owner', 'admin'];
    }
    function canWriteCollection(businessId, collectionName) {
      return belongsToBusiness(businessId)
        && (
          userProfile().role in ['owner', 'admin', 'manager']
          || (
            userProfile().role == 'cashier'
            && collectionName in [
              'clients', 'sales', 'payments', 'balanceEvents',
              'charges', 'messageHistory', 'catalogOrders'
            ]
          )
        );
    }
    function selfOnboardingBusinessId() {
      return 'biz_' + request.auth.uid;
    }
    function onboardingOwner(businessId) {
      return signedIn()
        && businessId == selfOnboardingBusinessId()
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId
        && getAfter(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.active == true
        && request.resource.data.role == 'owner'
        && request.resource.data.businessId == selfOnboardingBusinessId()
        && getAfter(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)).data.ownerId == uid;
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.active == resource.data.active
        && request.resource.data.businessId == resource.data.businessId
        && (
          request.resource.data.role == resource.data.role
          || (
            resource.data.businessId == 'adi-festa'
            && resource.data.role == 'admin'
            && request.resource.data.role == 'owner'
            && get(/databases/$(database)/documents/businesses/adi-festa).data.ownerId == request.auth.uid
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid', 'name', 'phone', 'role', 'permissions', 'onboardingCompleted',
          'lastLoginAt', 'updatedAt'
        ]);
      allow delete: if false;
    }

    match /publicCatalogs/{visitToken} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.businessId is string
        && belongsToBusiness(request.resource.data.businessId);
      allow update: if signedIn()
        && resource.data.businessId == request.resource.data.businessId
        && belongsToBusiness(resource.data.businessId);
      allow delete: if false;

      match /orders/{orderId} {
        function catalog() {
          return get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data;
        }
        allow create: if catalog().active == true
          && request.resource.data.id == orderId
          && request.resource.data.catalogToken == visitToken
          && request.resource.data.businessId == catalog().businessId
          && request.resource.data.visitId == catalog().visitId
          && request.resource.data.source == 'online_catalog'
          && request.resource.data.orderStatus == 'recebido'
          && request.resource.data.customerName is string
          && request.resource.data.customerName.size() > 1
          && request.resource.data.customerName.size() <= 120
          && request.resource.data.customerPhone is string
          && request.resource.data.customerPhone.size() >= 10
          && request.resource.data.customerPhone.size() <= 15
          && request.resource.data.customerLocation is string
          && request.resource.data.customerLocation.size() <= 160
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 1000
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 40
          && request.resource.data.total is number
          && request.resource.data.total > 0
          && request.resource.data.total <= 10000
          && request.resource.data.subtotal == request.resource.data.total
          && request.resource.data.discount == 0
          && request.resource.data.fee == 0
          && request.resource.data.paymentPreference in ['entrega', 'pix', 'dinheiro', 'cartao', 'fiado']
          && request.resource.data.orderAccessToken is string
          && request.resource.data.orderAccessToken.size() >= 24;
        allow get: if true;
        allow list, update: if signedIn() && belongsToBusiness(catalog().businessId);
        allow delete: if false;
      }

      match /campaignProgress/{phoneHash} {
        allow get: if true;
        allow list: if false;
        allow create, update: if signedIn() && belongsToBusiness(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /phoneIndex/{phoneHash} {
        allow get: if true;
        allow list: if false;
        allow create, update: if signedIn() && belongsToBusiness(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /portalProfiles/{clientRefToken} {
        allow get: if true;
        allow list: if false;
        allow create, update: if signedIn() && belongsToBusiness(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
      match /portalSessions/{sessionHash} {
        allow get: if true;
        allow list: if signedIn() && belongsToBusiness(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow create: if get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.active == true
          && request.resource.data.active == true
          && request.resource.data.businessId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId
          && request.resource.data.visitId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.visitId
          && request.resource.data.clientRefToken is string
          && request.resource.data.clientRefToken.size() >= 20
          && request.resource.data.expiresAt is string
          && exists(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalProfiles/$(request.resource.data.clientRefToken));
        allow update: if belongsToBusiness(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId)
          || (
            resource.data.active == true
            && request.resource.data.businessId == resource.data.businessId
            && request.resource.data.visitId == resource.data.visitId
            && request.resource.data.clientRefToken == resource.data.clientRefToken
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastAccessAt', 'updatedAt', 'active', 'revokedAt'])
          );
        allow delete: if false;
      }
      match /redemptionRequests/{requestId} {
        allow create: if request.resource.data.id == requestId
          && request.resource.data.status == 'solicitado'
          && request.resource.data.businessId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId
          && request.resource.data.visitId == get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.visitId
          && request.resource.data.clientRefToken is string
          && request.resource.data.portalSessionHash is string
          && exists(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalSessions/$(request.resource.data.portalSessionHash))
          && get(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalSessions/$(request.resource.data.portalSessionHash)).data.active == true
          && get(/databases/$(database)/documents/publicCatalogs/$(visitToken)/portalSessions/$(request.resource.data.portalSessionHash)).data.clientRefToken == request.resource.data.clientRefToken;
        allow get: if true;
        allow list, update: if signedIn() && belongsToBusiness(get(/databases/$(database)/documents/publicCatalogs/$(visitToken)).data.businessId);
        allow delete: if false;
      }
    }

    match /businesses/{businessId} {
      allow create: if signedIn()
        && businessId == selfOnboardingBusinessId()
        && request.resource.data.id == businessId
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.active == true
        && request.resource.data.onboardingCompleted == true
        && request.resource.data.subscription.planId == 'trial'
        && request.resource.data.subscription.status == 'trial'
        && request.resource.data.subscription.trialStartedAt <= request.time
        && request.resource.data.subscription.trialEndsAt > request.time + duration.value(6, 'd')
        && request.resource.data.subscription.trialEndsAt <= request.time + duration.value(8, 'd')
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
      allow read: if belongsToBusiness(businessId);
      allow update: if (
        isOwner(businessId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.slug == resource.data.slug
          && request.resource.data.subscription == resource.data.subscription
          && request.resource.data.limits == resource.data.limits
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'legalName', 'document', 'phone', 'email', 'businessType',
            'city', 'state', 'address', 'receiptName', 'active',
            'onboardingCompleted', 'updatedAt'
          ])
        )
        || (
          signedIn()
          && businessId == 'adi-festa'
          && resource.data.ownerId == request.auth.uid
          && !('subscription' in resource.data)
          && request.resource.data.subscription.planId == 'internal'
          && request.resource.data.subscription.status == 'active'
          && request.resource.data.ownerId == resource.data.ownerId
        );
      allow delete: if false;

      match /subscriptionIntents/{intentId} {
        allow read: if isOwner(businessId);
        allow create: if isOwner(businessId)
          && request.resource.data.businessId == businessId
          && request.resource.data.requestedBy == request.auth.uid;
        allow update, delete: if false;
      }
      match /invites/{inviteId} {
        allow read: if isAdmin(businessId);
        allow create: if isOwner(businessId)
          && request.resource.data.businessId == businessId
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.status == 'pending';
        allow update: if isOwner(businessId);
        allow delete: if false;
      }
      match /auditLogs/{logId} {
        allow read: if isOwner(businessId);
        allow create: if (belongsToBusiness(businessId) || onboardingOwner(businessId))
          && request.resource.data.businessId == businessId;
        allow update, delete: if false;
      }
      match /{collectionName}/{documentId} {
        allow read: if belongsToBusiness(businessId);
        allow create: if (canWriteCollection(businessId, collectionName) || onboardingOwner(businessId))
          && request.resource.data.businessId == businessId;
        allow update: if canWriteCollection(businessId, collectionName)
          && (
            resource.data.businessId == businessId
            || (businessId == 'adi-festa' && !('businessId' in resource.data))
          )
          && request.resource.data.businessId == businessId;
        allow delete: if false;
      }
    }
  }
}
