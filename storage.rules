rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function profile() { return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data; }
    function canAccess(businessId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && profile().active == true
        && profile().businessId == businessId;
    }
    match /businesses/{businessId}/products/{productId}/{fileName} {
      allow read: if true;
      allow create, update: if canAccess(businessId)
        && fileName.matches('^(main|thumb)\\.(webp|jpg)$')
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType.matches('image/(webp|jpeg)')
        && request.resource.metadata.businessId == businessId
        && request.resource.metadata.productId == productId;
      allow delete: if canAccess(businessId);
    }
  }
}
